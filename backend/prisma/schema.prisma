generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Domain {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  projects    Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  projectUrl  String?
  image       String?
  createdAt   DateTime @default(now())

  domainId    Int
  domain      Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
}